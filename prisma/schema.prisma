// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CAJERO
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  password           String
  name               String?
  role               Role      @default(CAJERO)
  refreshToken       String?
  mustChangePassword Boolean   @default(true)
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("users")
}

model Category {
  id        String    @id @default(uuid())
  name      String
  products  Product[]
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id         String        @id @default(uuid())
  name       String
  status     Int // 1 = Active, 2 = Inactive
  categoryId String
  category   Category      @relation(fields: [categoryId], references: [id])
  stock      Int
  price      ProductPrice?
  sales      SaleItem[]
  deletedAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("products")
}

model ProductPrice {
  id                 String    @id @default(uuid())
  productId          String    @unique
  product            Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  usdTarjeta         Float
  usdFisico          Float
  cop                Float
  ves                Float
  exchangeType       String // "usd" | "cop"
  isCustomUsdTarjeta Boolean   @default(false)
  isCustomUsdFisico  Boolean   @default(false)
  isCustomCop        Boolean   @default(false)
  isCustomVes        Boolean   @default(false)
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("product_prices")
}

model ExchangeRates {
  id        String   @id @default("singleton")
  cop       Float
  bcv       Float
  copUsd    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exchange_rates")
}

model Sale {
  id             String     @id @default(uuid())
  date           DateTime   @default(now())
  items          SaleItem[]
  receivedTotals Json // type { usdFisico, usdTarjeta, cop, ves }
  status         String // "pagado" | "fiado" | "debiendo"
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("sales")
}

model SaleItem {
  id         String    @id @default(uuid())
  saleId     String
  sale       Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId  String
  product    Product   @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Json // type Prices
  totalPrice Json // type Prices
  payments   Json // type { usdFisico, usdTarjeta, cop, ves }
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("sale_items")
}
